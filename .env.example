# Copy this file to .env and fill in real values to enable live email alerts.
# If left unset, the system runs in email dry-run mode (writes .eml files to reports/).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@solarplant.local
ALERT_EMAIL_TO=maintenance@solarplant.local,manager@solarplant.local

# Point at Postgres/MySQL/etc. instead of the default local SQLite file if desired.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/solar_monitoring

PANEL_COUNT=500
RATED_POWER_W=400
UNDERPERFORMANCE_THRESHOLD=0.80
PIPELINE_INTERVAL_MINUTES=5
